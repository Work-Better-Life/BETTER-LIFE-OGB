# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# brainstorming companion
.superpowers/

# local sqlite files (the app uses Turso in all real environments;
# these are only used locally by `prisma migrate dev` to generate migrations)
prisma/*.db
prisma/*.db-journal
prisma/*.db-shm
prisma/*.db-wal

# typescript
*.tsbuildinfo
next-env.d.ts
