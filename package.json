{
  "name": "student-recorder",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "create-account": "tsx --env-file=.env scripts/create-account.ts",
    "delete-account": "tsx --env-file=.env scripts/delete-account.ts",
    "seed-test-data": "tsx --env-file=.env scripts/seed-test-data.ts",
    "delete-all-students": "tsx --env-file=.env scripts/delete-all-students.ts",
    "renumber-students": "tsx --env-file=.env scripts/renumber-students.ts",
    "push-schema-to-turso": "tsx --env-file=.env scripts/push-schema-to-turso.ts",
    "seed": "tsx --env-file=.env prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
